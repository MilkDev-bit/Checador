# ──────────────────────────────────────────────
# PaseLista - Backend Environment Variables
# ──────────────────────────────────────────────

# ── DATABASE ──────────────────────────────────
# Option A (Railway): Use the full connection URL provided by Railway Postgres plugin
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Option B (local / Docker Compose): individual variables
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=paselista

# ── JWT ───────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars

# ── ADMIN SEED ────────────────────────────────
ADMIN_EMAIL=admin@paselista.com
ADMIN_PASSWORD=Admin1234!

# ── CORS ──────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Example: https://frontend.up.railway.app,https://myapp.com
FRONTEND_URL=https://frontend.up.railway.app

# ── SERVER ────────────────────────────────────
# Railway sets PORT automatically — no need to set this manually on Railway
PORT=8080
