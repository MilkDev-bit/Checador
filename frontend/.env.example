# ──────────────────────────────────────────────
# PaseLista - Frontend Environment Variables
# ──────────────────────────────────────────────

# ── BACKEND ───────────────────────────────────
# Internal URL of the backend service for nginx proxy (Railway private networking)
# Railway private networking: http://<service-name>.railway.internal:<PORT>
BACKEND_URL=http://backend.railway.internal:8080

# nginx listen port — Railway sets this automatically
PORT=80
